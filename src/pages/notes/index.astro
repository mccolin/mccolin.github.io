---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SHOW_NOTES } from "astro:env/server";

const allPosts = await getCollection('notes', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Notes" description="Writing by Colin McCloskey.">
  <div class="page-wrap">

    { SHOW_NOTES ? null : (
      <p class="warn">The Notes section is set to be hidden from navigation. You are accessing unpublished content via a direct path for testing/debug purposes only.</p>
    ) }

    <h1>Notes</h1>

    {posts.length === 0 ? (
      <p class="empty">No published notes are ready for you to read. Check back in the future.</p>
    ) : (
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <a href={`/notes/${post.id}`} class="post-link">
              <span class="post-title">{post.data.title}</span>
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </a>
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .warn {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    background: #fef3c7;
    color: #92400e;
    border: 1px solid #fbbf24;
    border-radius: 4px;
    padding: 0.6rem 0.9rem;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .warn::before {
    content: '⚠️';
    flex-shrink: 0;
    line-height: 1.4;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    color: var(--color-text);
  }

  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-title {
    font-weight: 600;
    transition: color 0.15s;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-desc {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
</style>
