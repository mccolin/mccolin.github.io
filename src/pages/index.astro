---
import BaseLayout from '../layouts/BaseLayout.astro';

const rawImages = import.meta.glob<string>('../assets/bgphotos/*.jpg', {
  query: '?url',
  import: 'default',
  eager: true,
});
const bgUrls = Object.values(rawImages);
---

<BaseLayout description="Personal site of Colin McCloskey.">
  <div class="page-wrap">
    <section class="intro">
      <h1>Hi. I'm Colin.</h1>
      <p>
        I work on software and think about it maybe a little too much.
        This is my corner of the internet — occasionally updated, always mine.
      </p>
      <p>
        You can find out <a href="/about">more about me</a>, look at my
        <a href="/resume">resume</a>, or read the <a href="/blog">blog</a>
        when I remember to write something.
      </p>
    </section>
  </div>
</BaseLayout>

<script is:inline define:vars={{ bgUrls }}>
  const url = bgUrls[Math.floor(Math.random() * bgUrls.length)];
  document.body.style.backgroundImage = `url('${url}')`;
  document.body.classList.add('has-bg-photo');

  const img = new Image();
  img.onload = () => {
    const canvas = document.createElement('canvas');
    canvas.width = 50;
    canvas.height = 50;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, 50, 50);
    const data = ctx.getImageData(0, 0, 50, 50).data;
    let r = 0, g = 0, b = 0;
    const pixels = data.length / 4;
    for (let i = 0; i < data.length; i += 4) {
      r += data[i];
      g += data[i + 1];
      b += data[i + 2];
    }
    r = Math.round((r / pixels) * 0.22);
    g = Math.round((g / pixels) * 0.22);
    b = Math.round((b / pixels) * 0.22);
    document.documentElement.style.setProperty('--scrim-color', `rgba(${r},${g},${b},0.82)`);
  };
  img.src = url;
</script>

<style is:global>
  body.has-bg-photo {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  body.has-bg-photo::before {
    content: '';
    position: fixed;
    inset: 0;
    background: var(--scrim-color, rgba(12, 10, 8, 0.82));
    transition: background 0.4s ease;
    z-index: 0;
    pointer-events: none;
  }

  body.has-bg-photo header,
  body.has-bg-photo main,
  body.has-bg-photo footer {
    position: relative;
    z-index: 1;
  }
</style>

<style>
  .intro {
    padding-top: clamp(3rem, 10vw, 6rem);
  }

  .intro h1 {
    margin-top: 0;
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .intro p {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 520px;
  }

  .intro a {
    color: var(--color-text);
  }
</style>
