---
import BaseLayout from '../layouts/BaseLayout.astro';
import { bgMap } from '../lib/bgphotos';

const greetings = [
  "👋 Hi. I'm Colin.",
  // "👀 You've found Colin McCloskey.",
  // "🍕 This is Colin McCloskey.",
];
---

<BaseLayout description="Personal site of Colin McCloskey." hideChrome={true}>
  <div class="scrim">
    <div class="page-wrap scrim-content">
      <h1>{greetings[Math.floor(Math.random() * greetings.length)]}</h1>
      <p>
        I'm a bearded, computery, nerd person based in Philadelphia, PA. I enjoy
        time with family and friends and love cheering on my favorite teams.
      </p>
      <p>
        Here you can learn <a href="/about">more about me</a> or take a look through
        my <a href="/resume">resume</a>. {/* or read a few semi-organized 
        <a href="/blog">thoughts</a> I've shared. */}
      </p>
      <nav>
        <a href="/about">About</a>
        <a href="/resume">Resume</a>
        {/* <a href="/blog">Blog</a> */}
      </nav>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ bgMap }}>
  const bgUrls = Object.values(bgMap);
  const bgParam = new URLSearchParams(window.location.search).get('bg');
  const url = (bgParam && bgMap[bgParam]) ? bgMap[bgParam] : bgUrls[Math.floor(Math.random() * bgUrls.length)];
  document.body.style.backgroundImage = `url('${url}')`;
  document.body.classList.add('has-bg-photo');

  const img = new Image();
  img.onload = () => {
    const canvas = document.createElement('canvas');
    canvas.width = 100;
    canvas.height = 100;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, 100, 100);
    const data = ctx.getImageData(0, 0, 100, 100).data;

    // Build a histogram of quantized colors (bucket size 24 per channel)
    const buckets = new Map();
    for (let i = 0; i < data.length; i += 4) {
      const r = Math.round(data[i] / 24) * 24;
      const g = Math.round(data[i + 1] / 24) * 24;
      const b = Math.round(data[i + 2] / 24) * 24;
      const key = `${r},${g},${b}`;
      buckets.set(key, (buckets.get(key) || 0) + 1);
    }

    // Find the most frequent bucket
    let max = 0, dominant = '12,10,8';
    for (const [key, count] of buckets) {
      if (count > max) { max = count; dominant = key; }
    }

    const [r, g, b] = dominant.split(',').map(v => Math.round(Number(v) * 0.22));
    document.documentElement.style.setProperty('--scrim-color', `rgba(${r},${g},${b},0.8)`);
  };
  img.src = url;
</script>

<style is:global>
  body.has-bg-photo {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }
</style>

<style>
  .scrim {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    padding-top: 6rem;
    background: linear-gradient(
      to bottom,
      transparent 0,
      var(--scrim-color, rgba(12, 10, 8, 0.96)) 6rem
    );
  }

  .scrim-content {
    padding-bottom: clamp(1.5rem, 4vh, 3rem);
  }

  .scrim-content h1 {
    margin-top: 0;
    margin-bottom: 0.6rem;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: #f9f7f4;
  }

  .scrim-content p {
    font-size: 1rem;
    color: rgba(249, 247, 244, 0.72);
    margin-bottom: 0.5rem;
    max-width: var(--max-width); /* 520px; */
  }

  .scrim-content p a {
    color: rgba(249, 247, 244, 0.9);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .scrim-content p a:hover {
    color: #f9f7f4;
    text-decoration: none;
  }

  .scrim-content nav {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.1rem;
  }

  .scrim-content nav a {
    color: rgba(249, 247, 244, 0.6);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.15s;
  }

  .scrim-content nav a:hover {
    color: #f9f7f4;
  }
</style>
