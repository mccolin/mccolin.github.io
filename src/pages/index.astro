---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getBgMap, getAllBgMap } from '../lib/bgphotos';
import { baseGreeting, siteGreetings } from '../lib/greetings';
import { SHOW_NOTES } from "astro:env/server";
const bgMap = await getBgMap();
const allBgMap = await getAllBgMap();
const greetings = siteGreetings();
---

<BaseLayout description="Personal site of Colin McCloskey." hideChrome={true}>
  <div class="scrim">
    <div class="page-wrap scrim-content">
      <h1>{baseGreeting()}</h1>
      <p>
        I'm a bearded, computery, nerd person based in Philadelphia, PA. I enjoy
        time with family and friends and love cheering on my favorite teams.
      </p>
      <p>
        { SHOW_NOTES ? (
          <span>Here you can <a href="/about">learn more about me</a>, take a peek at <a href="/resume">my resume</a>,
          or <a href="/notes">read a few notes</a> I've shared.</span>
        ) : (
          <span>Here you can <a href="/about">learn more about me</a> or take a look through
          <a href="/resume">my resume</a>.</span>
        ) }
        
      </p>
      <nav>
        <a href="/about">About</a>
        <a href="/resume">Resume</a>
        { SHOW_NOTES ? <a href="/notes">Notes</a> : null }
      </nav>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ bgMap, allBgMap }}>
  const bgPhotos = Object.values(bgMap);
  const bgParam = new URLSearchParams(window.location.search).get('bg');
  const selected = (bgParam && allBgMap[bgParam]) ? allBgMap[bgParam] : bgPhotos[Math.floor(Math.random() * bgPhotos.length)];
  const url = selected.url;
  document.body.style.backgroundImage = `url('${url}')`;
  if (selected.position) document.body.style.backgroundPosition = selected.position;
  document.body.classList.add('has-bg-photo');

  const img = new Image();
  img.onload = () => {
    const canvas = document.createElement('canvas');
    canvas.width = 100;
    canvas.height = 100;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, 100, 100);
    const data = ctx.getImageData(0, 0, 100, 100).data;

    // Build a histogram of quantized colors (bucket size 24 per channel)
    const buckets = new Map();
    for (let i = 0; i < data.length; i += 4) {
      const r = Math.round(data[i] / 24) * 24;
      const g = Math.round(data[i + 1] / 24) * 24;
      const b = Math.round(data[i + 2] / 24) * 24;
      const key = `${r},${g},${b}`;
      buckets.set(key, (buckets.get(key) || 0) + 1);
    }

    // Find the most frequent bucket
    let max = 0, dominant = '12,10,8';
    for (const [key, count] of buckets) {
      if (count > max) { max = count; dominant = key; }
    }

    // Darken the dominant color for the scrim
    const [r, g, b] = dominant.split(',').map(v => Math.round(Number(v) * 0.4));
    document.documentElement.style.setProperty('--scrim-color', `rgba(${r},${g},${b},0.8)`);

    const debugMode = new URLSearchParams(window.location.search).get('debug') === '1';
    if (debugMode) {
      console.log("Colin debug info:",{
        'Background image:': url,
        'Dominant color:': dominant,
        'Scrim color:': `rgba(${r},${g},${b},0.9)`
      });

      document.querySelector('body').appendChild(canvas);
      const colorBlock = document.createElement('div')
      colorBlock.style = "position: fixed; top: 0; left: 100px; width: 100px; height: 100px; background-color: var(--scrim-color);";
      document.querySelector('body').appendChild(colorBlock);
    };
  };
  img.src = url;
</script>

<script is:inline define:vars={{ greetings }}>
  // Replace the greeting on each visit for a bit of variety
  const gParam = new URLSearchParams(window.location.search).get('g');
  const greeting = gParam ? gParam : greetings[Math.floor(Math.random() * greetings.length)];
  document.querySelector('h1').textContent = greeting;
</script>

<style is:global>
  body.has-bg-photo {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }
</style>

<style>
  .scrim {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    padding-top: 6rem;
    background: linear-gradient(
      to bottom,
      transparent 0,
      var(--scrim-color, rgba(12, 10, 8, 0.96)) 8rem
    );
  }

  .scrim-content {
    padding-bottom: clamp(1.5rem, 4vh, 3rem);
  }

  .scrim-content h1 {
    margin-top: 0;
    margin-bottom: 0.6rem;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: #f9f7f4;
  }

  .scrim-content p {
    font-size: 1rem;
    color: rgba(249, 247, 244, 0.72);
    margin-bottom: 0.5rem;
    max-width: var(--max-width); /* 520px; */
  }

  .scrim-content p a {
    color: rgba(249, 247, 244, 0.9);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .scrim-content p a:hover {
    color: #f9f7f4;
    text-decoration: none;
  }

  .scrim-content nav {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.1rem;
  }

  .scrim-content nav a {
    color: rgba(249, 247, 244, 0.6);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.15s;
  }

  .scrim-content nav a:hover {
    color: #f9f7f4;
  }
</style>
