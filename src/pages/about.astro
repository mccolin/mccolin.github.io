---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

let previousEditions = (await getCollection('about'))
  .sort((a, b) => b.data.year - a.data.year);

const currentEdition = previousEditions.splice(0, 1)[0];
const { Content } = await render(currentEdition);
---

<BaseLayout title="About" description="A bit about Colin McCloskey.">
  <div class="page-wrap">
    <h1>About Colin</h1>

    <div class="about-body">
      <Content />
    </div>

    {previousEditions.length > 0 && (
      <section class="about-archive">
        <h2>Previous editions of this page</h2>
        <ul>
          {previousEditions.map(entry => (
            <li><a href={`/about/${entry.id}`}>{entry.data.year}</a></li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .about-archive {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .about-archive h2 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .about-archive ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
  }

  .about-archive a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
</style>
