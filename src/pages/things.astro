---
import BaseLayout from '../layouts/BaseLayout.astro';
import iconLink from '../assets/icon_link.svg?url';
import iconPhotoCity from '../assets/icon_photo_city.svg?url';

type ThingItem = {
  title: string;
  href: string;
  description?: string;
  thumb: string;
  cover?: boolean;
};

const sections: { label: string; items: ThingItem[] }[] = [
  {
    label: 'Links & Projects',
    items: [
      {
        title: 'WOSoMP',
        href: 'http://wosomp.com/',
        description: 'The Weekend Olympic Showdown of Massive Proportions.',
        thumb: iconLink,
      },
      {
        title: 'liz&colin',
        href: 'http://lizandcolin.us/',
        description: 'Our wedding website, 4/2/2011',
        thumb: '/things/lizandcolin.jpg',
      },
      {
        title: 'Happy Xmas 2007',
        href: '/things/xmas_2007/index.html',
        description: 'A holiday photo card from Christmas 2007.',
        thumb: '/things/xmas_2007/HappyXMas_files/IMG_4559.jpg',
        cover: true,
      },
    ],
  },
  {
    label: 'Images',
    items: [
      {
        title: 'Colin and Pepper',
        href: '/things/colin_and_pepper.jpg',
        description: "My mother-in-law's bird, Pepper, bonded with me when she was out-of-town for a few days.",
        thumb: '/things/colin_and_pepper.jpg',
        cover: true,
      },
      {
        title: 'Comic Sans',
        href: '/things/ComicSans.jpg',
        thumb: '/things/ComicSans.jpg',
        cover: true,
      },
      {
        title: 'Filbert',
        href: '/things/filbert.png',
        description: "I'm nautious!",
        thumb: '/things/filbert.png',
        cover: true,
      },
      {
        title: 'Illegal Mask Procedure',
        href: '/things/IllegalProcedureMask.PNG',
        description: 'Name and logo of my COVID-era fantasy football team.',
        thumb: '/things/IllegalProcedureMask.PNG',
        cover: true,
      },
      {
        title: 'The Phanatic and Me',
        href: '/things/PhanaticAndMe.jpg',
        description: 'Me and the Phillie Phanatic, circa 2010.',
        thumb: '/things/PhanaticAndMe.jpg',
        cover: true,
      },
      {
        title: 'Franklin Phanatic and Me',
        href: '/things/PhanaticFranklin.jpg',
        description: 'Phillie Phanatic as Ben Franklin',
        thumb: '/things/PhanaticFranklin.jpg',
        cover: true,
      },
      {
        title: 'Liz Laser Eyes',
        href: '/things/LizLaserEyes.gif',
        description: 'A delightful GIF of Liz with laser eyes, depicting her extreme annoyance with a client at work.',
        thumb: '/things/LizLaserEyes.gif',
        cover: true,
      },
    ],
  },
  {
    label: 'Media',
    items: [
      {
        title: 'Song Improvised About My Family',
        href: 'http://colinmccloskey.com/music/ClintAmbs_TheMcCloskeys.mp3',
        description: 'Clint Ambs wrote this risqué song about my mom and dad on the spot at a party in 2001.',
        thumb: iconPhotoCity,
      },
    ],
  },
];
---

<BaseLayout title="Things" description="A collection of things from around the internet.">
  <div class="page-wrap">
    <h1>Things</h1>
    <p class="intro">
      You've found the secret stash! Here's a collection of random things I just can't
      seem to get rid of and keep porting around whenever I redo my site.
    </p>

    {sections.map(({ label, items }) => (
      <section>
        <h2>{label}</h2>
        <ul class="grid">
          {items.map(({ title, href, description, thumb, cover }) => (
            <li>
              <a href={href} rel="noopener noreferrer">
                <div class="thumb">
                  {thumb
                    ? <img src={thumb} alt={title} class={cover ? 'cover' : undefined} />
                    : <span class="thumb-placeholder" aria-hidden="true" />
                  }
                </div>
                <strong>{title}</strong>
                {description && <span class="desc">{description}</span>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .intro {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  section {
    margin-bottom: 3rem;
  }

  section h2 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }

  .grid a {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.85rem;
    transition: opacity 0.15s;
  }

  .grid a:hover {
    opacity: 0.75;
  }

  .thumb {
    margin-bottom: 0.5rem;
  }

  .thumb img,
  .thumb-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    object-fit: contain;
    padding: 1rem;
  }

  .thumb img.cover {
    object-fit: cover;
    object-position: center;
    padding: 0;
  }

  .thumb-placeholder {
    background: var(--color-code-bg);
  }

  .grid strong {
    display: block;
    margin-bottom: 0.2rem;
  }

  .desc {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
</style>
